# Unsplash API Configuration
# Regístrate en: https://unsplash.com/oauth/applications
# 1. Ir a https://unsplash.com/oauth/applications
# 2. Crear nueva aplicación
# 3. Copiar Access Key
# 4. Pegar aquí sin comillas

VITE_UNSPLASH_KEY=tu_access_key_aqui

# Sin API key, Unsplash permite 50 requests/hora
# Con API key: 5000 requests/hora

# API backend (ajusta según tu entorno)
# XAMPP/Apache: http://localhost/delivery-appifood/Backend/public/api
# Laravel artisan serve: http://localhost:8000/api
VITE_API_URL=http://localhost/delivery-appifood/Backend/public/api
