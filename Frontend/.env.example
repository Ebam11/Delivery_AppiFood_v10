# ========== API CONFIGURATION ==========
# URL del backend API (sin trailing slash)
# LOCAL (php artisan serve): http://localhost:8000/api
# LOCAL (XAMPP): http://localhost/delivery-appifood/Backend/public/api
# PROD: https://api.appifood.com/api
VITE_API_URL=http://localhost:8000/api

# ========== APP CONFIGURATION ==========
# Nombre de la aplicación
VITE_APP_NAME=AppiFood

# Ambiente (development, staging, production)
VITE_ENV=development

# ========== FEATURE FLAGS ==========
# Habilitar modo debug (console logs)
VITE_DEBUG=true

# Habilitar chat IA
VITE_ENABLE_AI_CHAT=true

# Habilitar seguimiento de pedidos en tiempo real
VITE_ENABLE_REALTIME_TRACKING=true

# ========== UNSPLASH API (para imágenes) ==========
# Regístrate en: https://unsplash.com/oauth/applications
# Sin API key: 50 requests/hora
# Con API key: 5000 requests/hora
VITE_UNSPLASH_KEY=oVPaIIGLQXMc7iWci_of_hgTPoi9vfJ8pw2Cx1pJxOA

# ========== PAYMENT GATEWAY (opcional) ==========
# PayU
VITE_PAYU_PUBLIC_KEY=

# Mercado Pago
VITE_MERCADOPAGO_PUBLIC_KEY=

# ========== THIRD PARTY SERVICES (opcional) ==========
# Google Maps
VITE_GOOGLE_MAPS_API_KEY=

# Google Analytics
VITE_GOOGLE_ANALYTICS_ID=

# Sentry (error tracking)
VITE_SENTRY_DSN=
