APP_NAME=AppiFood
APP_ENV=production
APP_KEY=base64:tu_app_key_aqui_generado_con_php_artisan_key_generate
APP_DEBUG=false
APP_URL=https://tu-dominio-railway.railway.app

# Base de datos (Railway proporciona estas variables automáticamente)
# Si no están disponibles, configúralas en el panel de Railway
DB_CONNECTION=mysql
DB_HOST=${RAILWAY_DB_HOST:-localhost}
DB_PORT=${RAILWAY_DB_PORT:-3306}
DB_DATABASE=${RAILWAY_DB_DATABASE:-railway}
DB_USERNAME=${RAILWAY_DB_USER:-root}
DB_PASSWORD=${RAILWAY_DB_PASSWORD}

# Cache y Session
CACHE_DRIVER=array
SESSION_DRIVER=cookie

# Mail (opcional, para desarrollo)
MAIL_MAILER=log
MAIL_FROM_ADDRESS=noreply@appifood.com

# API
SANCTUM_STATEFUL_DOMAINS=localhost,127.0.0.1,tu-dominio-railway.railway.app
SESSION_DOMAIN=.tu-dominio-railway.railway.app

# Configuración de archivos
FILESYSTEM_DISK=public

# Queue (mantener como sync en Railway sin Redis)
QUEUE_CONNECTION=sync

# Las siguientes fueron agregadas en el pull
OPENAI_API_KEY=sk_test_tu_key_aqui
ANTHROPIC_API_KEY=tu_key_aqui
OLLAMA_BASE_URL=http://localhost:11434
SERVICES_SUPPORT_AI_PROVIDER=openai
SERVICES_SUPPORT_AI_TEMPERATURE=0.3
SERVICES_SUPPORT_AI_MAX_TOKENS=350
